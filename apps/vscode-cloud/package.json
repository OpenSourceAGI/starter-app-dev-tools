{
  "name": "vscode-cloud",
  "version": "1.0.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit",
    "build": "tsc --noEmit && echo 'Type check passed — wrangler bundles on deploy'",
    "local": "docker compose -f compose.yml -f compose.local.yml up",
    "local:build": "docker compose -f compose.yml -f compose.local.yml up --build",
    "local:down": "docker compose -f compose.yml -f compose.local.yml down",
    "local:clean": "docker compose -f compose.yml -f compose.local.yml down -v"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.3",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.85.0"
  }
}
