    "@radix-ui/react-tooltip": "^1.2.8",
    "@typescript-eslint/typescript-estree": "^8.56.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.11.5",
    "fumadocs-mdx": "^15.2.0",
    "fumadocs-openapi": "^11.2.2",
