{
  "name": "manage-storage",
  "version": "0.0.8",
  "description": "Storage manager supporting AWS S3, Backblaze B2, and Cloudflare R2 with automatic provider detection",
  "main": "./dist/manage-storage.js",
  "module": "./dist/manage-storage.js",
  "types": "./dist/manage-storage.d.ts",
  "type": "module",
  "keywords": [
    "s3",
    "r2",
    "b2",
    "cloudflare",
    "backblaze",
    "aws",
    "amazon",
    "storage",
    "cloud",
    "cloud-storage",
    "file-storage",
    "multi-cloud"
  ],
  "author": "vtempest",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenSourceAGI/appdemo-dev-tools/tree/master/packages/manage-storage"
  },
  "homepage": "https://github.com/OpenSourceAGI/appdemo-dev-tools/tree/master/packages/manage-storage",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.965.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "ship": "npx standard-version --release-as patch; rm CHANGELOG.md; npm publish"
  },
  "exports": {
    ".": {
      "types": "./dist/manage-storage.d.ts",
      "import": "./dist/manage-storage.js"
    }
  },
  "files": [
    "dist"
  ]
}
