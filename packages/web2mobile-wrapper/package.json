{
  "name": "create-mobile-wrapper",
  "version": "1.0.0",
  "main": "src/generate.js",
  "bin": {
    "create-mobile-wrapper": "./bin/cli.js"
  },
  "scripts": {
    "start": "cd mobile-app && expo start",
    "android": "cd mobile-app && expo start --android",
    "ios": "cd mobile-app && expo start --ios",
    "web": "cd mobile-app && expo start --web",
    "generate": "node ./bin/cli.js",
    "build:android": "cd mobile-app && eas build --platform android",
    "build:ios": "cd mobile-app && eas build --platform ios",
    "build:all": "cd mobile-app && eas build --platform all",
    "build:production": "cd mobile-app && eas build --platform all --profile production",
    "submit:android": "cd mobile-app && eas submit --platform android",
    "submit:ios": "cd mobile-app && eas submit --platform ios",
    "submit:all": "cd mobile-app && eas submit --platform all",
    "test": "jest"
  },
  "dependencies": {
    "expo": "~52.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-webview": "13.12.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "eas-cli": "^14.2.0",
    "jest": "^30.2.0",
    "sharp": "^0.33.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenSourceAGI/starter-app-dev-tools/tree/master/packages/web2mobile-wrapper"
  },
  "homepage": "https://github.com/OpenSourceAGI/starter-app-dev-tools/tree/master/packages/web2mobile-wrapper",
  "private": true
}