{
  "name": "shadcn-theme-menu",
  "version": "1.1.11",
  "description": "A collection of beautiful shadcn/ui theme components with dynamic theme switching and animations",
  "author": "vtempest",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenSourceAGI/appdemo-dev-tools/tree/master/packages/shadcn-theme-menu"
  },
  "homepage": "https://github.com/OpenSourceAGI/appdemo-dev-tools/tree/master/packages/shadcn-theme-menu",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./themes.css": "./src/themes-shadcn.css"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "ship": "npm run build; npx standard-version --release-as patch; rm CHANGELOG.md; npm publish",
    "demo": "cd demo && pnpm dev"
  },
  "sideEffects": [
    "*.css"
  ],
  "keywords": [
    "shadcn",
    "shadcn-ui",
    "themes",
    "theme-switcher",
    "dark-mode",
    "light-mode",
    "react",
    "nextjs",
    "tailwind"
  ],
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "framer-motion": ">=11.0.0",
    "lucide-react": ">=0.400.0",
    "next-auth": ">=4.0.0",
    "next-themes": ">=0.3.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "framer-motion": {
      "optional": true
    },
    "next-auth": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^2.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.0"
  }
}
